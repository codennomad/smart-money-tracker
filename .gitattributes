# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for all source files
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary — no line-ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
*.woff  binary
